# ============================================
# TIMESHEET APP v2 - Configurazione
# Copia questo file in .env e compila i valori
# ============================================

# Porta del server locale
APP_PORT=5599

# Nome utente (appare nell'app)
USER_NAME=Il Tuo Nome

# Account Outlook da usare
OUTLOOK_ACCOUNT=tuo@email.com

# OpenAI API Key (richiesta per elaborazione AI)
OPENAI_API_KEY=sk-...

# ---- Webhook n8n (opzionale, disabilitato di default) ----
ENABLE_WEBHOOK=false
WEBHOOK_URL=https://tuo-n8n.cloud/webhook/...
